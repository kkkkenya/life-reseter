# Copy this file to .env and fill in your own values.
#
# IMPORTANT — two different kinds of variable here:
#   VITE_...   → gets baked into the browser bundle. Anyone can read these
#                in dev tools. Fine for URLs and non-secret flags, NEVER for
#                real secrets.
#   (no VITE_) → server-only. Read via process.env inside api/*.ts, never
#                shipped to the browser. Real secrets go here.
# In Vercel, both kinds are set the same way (Project Settings > Environment
# Variables) — the VITE_ prefix is what decides visibility, not where you set it.

# --- Gemini (server-only key; get one at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your_key_here
# Optional — defaults to gemini-3.1-flash-lite if unset (gemini-2.0-flash was
# retired March 31, 2026). For deeper/slower reasoning on the weekly report,
# try gemini-3.1-pro-preview instead (no free tier).
# GEMINI_MODEL=gemini-3.1-flash-lite

# Non-secret client-side flag — set to "true" once GEMINI_API_KEY above is set,
# so the app knows to show AI-powered UI. Not a key, safe to be public.
VITE_GEMINI_ENABLED=true

# --- Supabase (cloud sync, optional) ---
# Leave both unset and the app runs local-only (localStorage), exactly as before.
# Project Settings > API Keys in your Supabase dashboard — use the PUBLISHABLE
# key (sb_publishable_..., or legacy "anon/public" key). NEVER the secret key
# (sb_secret_..., or legacy service_role) — this app has no use for it anywhere,
# and Supabase blocks it from working in a browser if you try.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here
